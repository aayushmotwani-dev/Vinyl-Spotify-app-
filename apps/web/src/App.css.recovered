    height: 24px;
    fill: currentColor;
  }

  .tab-nav-btn.active {
    color: #e5b07b;
  }
}

/* Hide tab nav on desktop */
@media (min-width: 1025px) {
  .mobile-tab-nav {
    display: none;
  }
}

/* Compress UI vertically on extremely short screens instead of scrolling */
@media (max-height: 850px) and (min-width: 1025px) {
  .left-panel {
    gap: 1rem;
    padding: 1.5rem;
  }
  .mini-panel {
    gap: 0.5rem;
  }
  .customization-group select {
    padding: 0.5rem 2.5rem 0.5rem 1rem;
    font-size: 0.85rem;
  }
}

@media (max-height: 700px) and (min-width: 1025px) {
  .left-panel {
    gap: 0.5rem;
    padding: 1rem;
  }
  .customization-group select {
    padding: 0.4rem 2rem 0.4rem 0.8rem;
    min-height: 30px;
  }
}

@media (max-width: 600px) {
  .split-layout {
    padding: 1rem;
  }
  
  .turntable-chassis {
    transform: scale(min(1, calc(100vw / 820)));
}

@media (max-height: 700px) and (min-width: 1025px) {
  .left-panel {
    gap: 0.5rem;
    padding: 1rem;
  }
  .customization-group select {
    padding: 0.4rem 2rem 0.4rem 0.8rem;
    min-height: 30px;
  }
}

@media (max-width: 600px) {
  .split-layout {
    padding: 1rem;
  }
  
  .turntable-chassis {
    transform: scale(min(1, calc(100vw / 820)));
  }
}
.controls button:hover, .customization-group button:hover {
  background: var(--button-hover-bg, #1a1a1a) !important;
  border-color: var(--button-hover-border, #646cff) !important;
  box-shadow: 0 0 15px var(--button-hover-border, transparent);
}
.controls button:focus,
.controls button:focus-visible {
  outline: 4px auto var(--button-hover-border, #646cff) !important;
}

.theme-holographic .record {
  background-color: rgba(0, 0, 0, 0.2) !important;
  backdrop-filter: blur(8px) saturate(150%);
  -webkit-backdrop-filter: blur(8px) saturate(150%);
  border: 2px solid rgba(34, 211, 238, 0.4);
  box-shadow: 0 0 20px rgba(34, 211, 238, 0.2), inset 0 0 30px rgba(34, 211, 238, 0.1);
}

.theme-holographic .record-grooves {
  opacity: 0.3;
}

  }
}

@media (max-width: 600px) {
  .split-layout {
    padding: 1rem;
  }
}
.controls button:hover, .customization-group button:hover {
  background: var(--button-hover-bg, #1a1a1a) !important;
  border-color: var(--button-hover-border, #646cff) !important;
  box-shadow: 0 0 15px var(--button-hover-border, transparent);
}
.controls button:focus,
.controls button:focus-visible {
  outline: 4px auto var(--button-hover-border, #646cff) !important;
}

.theme-holographic .record {
  background-color: rgba(0, 0, 0, 0.2) !important;
  backdrop-filter: blur(8px) saturate(150%);
  -webkit-backdrop-filter: blur(8px) saturate(150%);
  border: 2px solid rgba(34, 211, 238, 0.4);
  box-shadow: 0 0 20px rgba(34, 211, 238, 0.2), inset 0 0 30px rgba(34, 211, 238, 0.1);
}

.theme-holographic .record-grooves {
  opacity: 0.3;
