/* FULL SCREEN MODE */
.full-screen-mode .left-panel,
.full-screen-mode .shelf-section,
.full-screen-mode .mobile-tab-nav,
.full-screen-mode .peek-cue {
  display: none !important;
}

.full-screen-mode .turntable-chassis {
  max-width: 100vw !important;
  transform: none !important;
}

.full-screen-mode.split-layout {
  display: flex !important;
  flex-direction: column;
  padding: 0 !important;
}

.full-screen-mode .desktop-right-col {
  height: 100dvh;
  width: 100vw;
  overflow: hidden;
  display: flex !important;
}

.full-screen-mode .right-panel {
  height: 100dvh !important;
  width: 100vw !important;
  padding: 0 !important;
  margin: 0 !important;
}

.full-screen-mode .turntable-viewport {
  height: 100dvh !important;
  min-height: 100dvh !important;
  padding: 0 !important;
}

/* Button styles */
.full-screen-toggle {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(0,0,0,0.5);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  color: white;
  width: 44px;
  height: 44px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  z-index: 100;
  transition: all 0.2s;
  backdrop-filter: blur(5px);
}
.full-screen-toggle:hover {
  background: rgba(255,255,255,0.1);
  transform: scale(1.05);
}

